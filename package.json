{
  "name": "amdm",
  "version": "0.3.0",
  "description": "AMDM (Another Mongo Desktop Manager) — a lean, performance-first desktop GUI for MongoDB (NoSQLBooster alternative)",
  "main": "./out/main/index.js",
  "author": "shawn",
  "license": "MIT",
  "type": "commonjs",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test": "vitest run",
    "test:unit": "vitest run test/unit test/contract",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@base-ui/react": "1.5.0",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fontsource/source-code-pro": "^5.2.7",
    "@mongosh/async-rewriter2": "^2.4.15",
    "@tanstack/react-virtual": "^3.10.9",
    "@uiw/codemirror-themes": "^4.25.10",
    "@uiw/react-codemirror": "^4.23.6",
    "bson": "^6.9.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "mongodb": "^6.10.0",
    "prettier": "^3.8.3",
    "react-i18next": "^17.0.8",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.29.7",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ssh2": "^1.15.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "exceljs": "^4.4.0",
    "mongodb-memory-server": "^11.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9",
    "zustand": "^5.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
